// Marks New York opening range on a chart, tracks FVG breakouts, signals entries
// with shapes while managing session resets and box updates dynamically.
// © Timo Anttila, Tuspe Design Oy
//@version=6
indicator("Opening Range with FVG Breakouts [timoanttila]", shorttitle="ORB FVG", overlay=true, max_boxes_count=300, max_labels_count=300)

// ----------
//  SETTINGS
// ----------

ny_sesh = input.session("1330-1345", "New York Open")
ny_stop = input.session("1346-1600", "Time to stop looking for FVG")
tz = "UTC"
min_fvg_body_perc = input.int(50, "Min FVG middle candle body %", minval=20, maxval=95)
min_fvg_third_body_perc = input.int(30, "Min FVG third candle body %", minval=20, maxval=95)

// Style colors (inline, one row each)
ny_bg = input.color(color.new(color.aqua, 95), "New York", inline="sesh", group="Style")
ny_brdr = color.new(ny_bg, 60)

n_bars = input.int(6, "Numbers of clearing bars")

// ----------
//  GLOBAL VARIABLES
// ----------

int entry_break = 0
int entry_test = 0
var bool all_done = false
var bool fvg_confirmed = false
var bool fvg_retest_valid = false
var bool fvg_tested = false
var box or_bx = na
var float fvg_high = na
var float fvg_low = na
var float fvg_test_clear = 0
var float orh = na
var float orl = na
var int breakout_dir = 0

// ----------
//  SESSION & TIME
// ----------

in_orb = not na(time(timeframe.period, ny_sesh, tz))
new_orb = in_orb and not in_orb[1]

// Check if current hour >= 16:00 UTC (12:00 NY)
time_range = not na(time(timeframe.period, ny_stop, tz))

// New session: reset shared state and create new persistent box
if new_orb
    all_done := false
    breakout_dir := 0
    fvg_confirmed := false
    fvg_high := na
    fvg_low := na
    fvg_retest_valid := false
    fvg_test_clear := 0
    fvg_tested := false

    orh := high
    orl := low
    or_bx := box.new(bar_index, high, bar_index, low, border_color=ny_brdr, bgcolor=ny_bg)

// Update box: grow top/bottom during session, extend right until FVG confirmed or stop time
if not na(or_bx)
    if in_orb
        orh := math.max(orh, high)
        orl := math.min(orl, low)
        box.set_top(or_bx, orh)
        box.set_bottom(or_bx, orl)
    if not fvg_confirmed and time_range
        box.set_right(or_bx, bar_index)

// ----------
//  FVG DETECTION
// ----------

bool fvg_third_outside = false

if not in_orb and time_range and not fvg_confirmed
    // Calculate middle candle (candle[1]) body percentage
    middle_body = math.abs(close[1] - open[1])
    middle_range = high[1] - low[1]
    middle_body_pct = middle_range > 0 ? (middle_body / middle_range) * 100 : 0

    // Calculate current candle (third candle) body percentage
    third_body = math.abs(close - open)
    third_range = high - low
    third_body_pct = third_range > 0 ? (third_body / third_range) * 100 : 0

    // Check if middle candle meets minimum body requirement
    strong_middle = middle_body_pct >= min_fvg_body_perc
    // Check if third candle is not a doji
    strong_third = third_body_pct >= min_fvg_third_body_perc

    // Bullish FVG: gap between candle[2] high and current candle low
    if high[2] < low and close[1] > open[1] and close > open and close > orh and strong_middle and strong_third
        breakout_dir := 1
        entry_break := 1
        fvg_confirmed := true
        fvg_high := low
        fvg_low := high[2]

    // Bearish FVG: gap between candle[2] low and current candle high
    else if low[2] > high and close[1] < open[1] and close < open and close < orl and strong_middle and strong_third
        breakout_dir := 2
        entry_break := 2
        fvg_confirmed := true
        fvg_high := low[2]
        fvg_low := high

// ----------
//  FVG RETEST LOGIC (Handles subsequent bars after FVG confirmation)
// ----------

float bear_lowest = ta.lowest(low, n_bars)[1]
float bull_highest = ta.highest(high, n_bars)[1]

if not all_done and time_range
    bool tested = false

    if fvg_confirmed and not fvg_retest_valid and breakout_dir > 0
        if (breakout_dir == 1 and fvg_low > close) or (breakout_dir == 2 and fvg_high < close)
            entry_test := breakout_dir == 1 ? 2 : 1
            all_done := true

        else if fvg_test_clear == 0
            if breakout_dir == 1 and fvg_high > low
                fvg_test_clear := high

            else if breakout_dir == 2 and fvg_low < high
                fvg_test_clear := low

            if fvg_test_clear > 0
                tested := true

        if entry_test == 0 and fvg_test_clear > 0 and ((breakout_dir == 1 and close > fvg_high and close > open) or (breakout_dir == 2 and close < fvg_low and close < open))
            fvg_retest_valid := true

    if fvg_retest_valid and fvg_test_clear > 0
        if breakout_dir == 1 and close > open and close > bull_highest and (close > fvg_test_clear or (tested and close > open))
            entry_test := 1

        else if breakout_dir == 2 and close < open and close < bear_lowest and (close < fvg_test_clear or (tested and close < open))
            entry_test := 2

        if entry_test > 0
            all_done := true

// ----------
//  BIAS
// ----------

daily_open = request.security(syminfo.tickerid, "D", open, lookahead=barmerge.lookahead_on)
daily_bias = daily_open < close ? 1 : 2
bool strong_trend = daily_bias == breakout_dir

// ----------
//  VISUAL INDICATORS
// ----------

plot_bear = location.abovebar
plot_bull = location.belowbar
plot_color_bear = color.new(strong_trend ? color.red : color.white, 20)
plot_color_bull = color.new(strong_trend ? color.green : color.white, 20)
plot_size = size.tiny

// FVG Confirmation Triangle
plotshape(entry_break == 1, title="Bull FVG Confirmed", style=shape.triangleup, location=plot_bull, size=plot_size, color=plot_color_bull)
plotshape(entry_break == 2, title="Bear FVG Confirmed", style=shape.triangledown, location=plot_bear, size=plot_size, color=plot_color_bear)

plotshape(entry_test == 1, title="FVG Break/Invalidation Flag", style=shape.flag, location=plot_bull, size=plot_size, color=plot_color_bull)
plotshape(entry_test == 2, title="FVG Valid Retest Flag", style=shape.flag, location=plot_bear, size=plot_size, color=plot_color_bear)


// ----------
//  ALERTS
// ----------

alertcondition(entry_break > 0, title="FVG Confirmed", message="Price broke out of the opening range with a Fair Value Gap.")
alertcondition(entry_test > 0, title="FVG Retest Confirmed", message="Price tested the Fair Value Gap and continued in its original direction.")
